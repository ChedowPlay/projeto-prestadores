## Headers

É necessário informar o Content-Type no header da requisição:
Exemplo para a maioria das APIs:
```
{
 "Content-Type": "application/json" 
}
```
Exemplo para APIs que solicitam o token de acesso:
```
{
 "Content-Type": "application/json",
 "authorization": "Bearer <<token>>"
}
```
Exemplo para APIs que permitem o envio de arquivos:
```
{
 "Content-Type": "multipart/form-data"
 "authorization": "Bearer <<token>>"
}
```

## Env

env do backend

```
VERSION=1.0250317


# SERVIDOR
PORT=3001
HOST=""
URL=null # Se tiver "https://www.site.com.br:443", ou "null"


# GERAL
DEBUG=true # false se for para rodar em produção
CLUSTERIZE=false
SECRETKEY=""
TIMEZONE="America/Campo_Grande"
PATH_LOG="./"
PROFILE_PIC_API="https://api.dicebear.com/9.x/initials/png?seed="


# MERCADO PAGO
MP_CLIENT_SECRET=""
MP_BACK_SUCCESS="https://webhook.site/ea8cc690-dea8-4755-8da5-581ee1fc672c"
MP_BACK_FAILURE="https://webhook.site/ea8cc690-dea8-4755-8da5-581ee1fc672c"
MP_BACK_PENDING="https://webhook.site/ea8cc690-dea8-4755-8da5-581ee1fc672c"


# BANCO DE DADOS TESTE
DB_TEST_DIALECT="sqlite"
DATABASE_TEST="bancoTeste.sqlite"


# BANCO DE DADOS PROD
DB_DIALECT="sqlite"
DATABASE="banco.sqlite"

# DB_DIALECT="postgres"
# DATABASE="dev_diboaclub"
DB_HOST=""
DB_PORT=5432
DB_USERNAME=""
DB_PASSWORD=""
DB_SSL=true


# EMAIL
SEND_EMAILS=true #1 = VERDADEIRO; NADA = FALSO
EMAIL_SMTP_HOST="smtp.hostinger.com"
EMAIL_SMTP_PORT=587
EMAIL_SERVICE=null
EMAIL_USER=""
EMAIL_PASS=""
```


