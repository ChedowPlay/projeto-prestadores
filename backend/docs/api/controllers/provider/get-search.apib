### **Funcionamento do services**
```javascript
/**
* listaIds: Itens que o cliente quer
* length: Valor total da lista
*/
const formatarListaBin = (listaIds, length) => {
    const ordenada = listaIds.sort((a, b) => a - b);
    // Cria um array de tamanho 'length' com todos os valores iniciados em 0
    const resultado = Array(length).fill(0);
    // Preenche as posições corretas com 1 (com base no índice do ID)
    ordenada.forEach(id => {
        if (id <= length) {
            resultado[length - id] = 1;  // Mapeia o ID para a posição correta (invertida)
        }
    });
    console.log("bin gerado:", resultado.join());
    return resultado;
};

const binToDec = (listaBinaria) => {
    const dec = listaBinaria.reduce((decimal, bit, index) => {
        return decimal + bit * Math.pow(2, listaBinaria.length - 1 - index);
    }, 0);
    console.log("dec:", dec);
    return dec;
};

// Exemplo
// Cliente escolheu os itens 1, 24 e 14
// A lista possui um total de 40 itens, use o totalServices no lugar do 40!!!
const totalServices = Object.values(data).reduce((count, category) => count + category.length, 0);
const lista = formatarListaBin([1, 24, 14], 40);
const services = binToDec(lista);
// `?services=${services}`
```

+ Parameters
    + page: `1` (number, optional) - Número da página
        + Default: 1
    + minprice: `50` (number, optional) - Preço mínimo
    + maxprice: `200` (number, optional) - Preço máximo
    + sortprice: `asc` (enum[string], optional) - Ordenar por preço
        + Members
            + `asc`
            + `desc`
    + lat: `-23.5505` (number, optional) - Latitude (-90 to 90)
    + lon: `-46.6333` (number, optional) - Longitude (-180 to 180)
    + mindistance: `1` (number, optional) - Distância mínima em km (0 a 1000)
    + maxdistance: `10` (number, optional) - Distância máxima em km (0 a 1000)
    + sortdistance: `asc` (enum[string], optional) - Ordenar por distância
        + Members
            + `asc`
            + `desc`
    + services: `7` (number, optional) - Número decimal que representa os serviços selecionados
    + state: `MS` (string, optional) - UF do estado (2 caracteres)
    + cities: `3` (number, optional) - Número decimal que representa as cidades selecionadas (mesmo funcionamento do services). Essa opção não requer o uso de state, pois cada id de city é único. Mesmo que duas cidades tenham o mesmo nome em Estados diferentes, seus ids serão distintos.

